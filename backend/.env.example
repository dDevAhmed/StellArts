# Database
DATABASE_URL=postgresql://user:password@localhost:5432/stellarts_db

# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API
API_V1_STR=/api/v1
PROJECT_NAME=Stellarts
DEBUG=True

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# Email (for future use)
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=
SMTP_PASSWORD=

# External APIs (for future use)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Stellar/Soroban Configuration
# Network options: standalone, testnet, mainnet
STELLAR_NETWORK=standalone
STELLAR_RPC_URL=http://localhost:8002/soroban/rpc

# Soroban network passphrase (required for transaction signing)
SOROBAN_NETWORK_PASSPHRASE=Standalone Network ; September 2022
STELLAR_NETWORK_PASSPHRASE=Standalone Network ; September 2022

# Escrow public key (for Horizon-based payments, legacy)
STELLAR_ESCROW_PUBLIC=

# Backend Secret Key for signing Soroban contract invocations (Admin)
BACKEND_SECRET_KEY=

# Soroban Contract IDs
ESCROW_CONTRACT_ID=
REPUTATION_CONTRACT_ID=
